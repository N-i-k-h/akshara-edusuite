# MongoDB Connection String
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=Cluster0

# Server Port
PORT=5000

# JWT Secret — generate a strong random string (min 32 chars)
JWT_SECRET=change_this_to_a_strong_random_secret_key_min_32_chars

# Allowed Frontend Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-production-domain.com

# Admin seed credentials (used only on first run)
ADMIN_EMAIL=admin@ssscp.com
ADMIN_PASSWORD=change_this_admin_password
